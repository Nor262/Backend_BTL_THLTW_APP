generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique @db.VarChar(100)
  email         String   @unique @db.VarChar(255)
  password_hash String   @db.VarChar(255)
  full_name     String?  @db.VarChar(255)
  role          String   @default("borrower") @db.VarChar(50) // admin, storekeeper, borrower
  phone         String?  @db.VarChar(20)
  avatar_url    String?  @db.Text
  reset_otp     String?  @db.VarChar(10)
  reset_otp_expires DateTime? @db.Timestamp(0)
  penalty_points Int     @default(0)
  email_notifications_enabled Boolean @default(true)
  fcm_token     String?  @db.Text
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now()) @db.Timestamp(0)

  // Relations
  borrowed_txs  Transaction[]  @relation("BorrowerTransactions")
  approved_txs  Transaction[]  @relation("ApproverTransactions")
  handled_txs   Transaction[]  @relation("StorekeeperTransactions")
  notifications Notification[]
  auditLogs     AuditLog[]

  @@map("users")
}

model EquipmentCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(255)
  description String?  @db.Text
  created_at  DateTime @default(now()) @db.Timestamp(0)

  equipment Equipment[]

  @@map("equipment_categories")
}

model Supplier {
  id           Int     @id @default(autoincrement())
  name         String  @db.VarChar(255)
  contact_info String? @db.Text
  address      String? @db.VarChar(500)

  equipment Equipment[]

  @@map("suppliers")
}

model StorageLocation {
  id         Int     @id @default(autoincrement())
  name       String  @db.VarChar(255)
  address    String? @db.VarChar(500)
  manager_id Int? // Note: Can be linked to User if needed

  equipment Equipment[]

  @@map("storage_locations")
}

model Equipment {
  id                Int       @id @default(autoincrement())
  category_id       Int
  supplier_id       Int?
  location_id       Int?
  name              String    @db.VarChar(255)
  serial_number     String    @unique @db.VarChar(100)
  sku               String?   @unique @db.VarChar(100)
  status            String    @default("available") @db.VarChar(50) // available, in_use, broken, maintenance
  specifications    Json?
  qr_code_data      String    @unique @db.VarChar(500)
  image_url         String?   @db.Text
  purchase_date     DateTime? @db.Date
  current_condition String?   @db.Text

  // Relations
  category         EquipmentCategory    @relation(fields: [category_id], references: [id])
  supplier         Supplier?            @relation(fields: [supplier_id], references: [id])
  location         StorageLocation?     @relation(fields: [location_id], references: [id])
  transactions     Transaction[]
  maintenance_hist MaintenanceHistory[]

  @@map("equipment")
}

model Transaction {
  id                     Int       @id @default(autoincrement())
  equipment_id           Int
  borrower_id            Int
  approver_id            Int?
  storekeeper_id         Int?
  type                   String    @db.VarChar(50) // borrow, return
  status                 String    @db.VarChar(50) // pending, approved, rejected, completed, overdue
  request_date           DateTime  @default(now()) @db.Timestamp(0)
  start_date             DateTime  @default(now()) @db.Timestamp(0)
  approval_date          DateTime? @db.Timestamp(0)
  due_date               DateTime  @db.Timestamp(0)
  actual_check_out       DateTime? @db.Timestamp(0)
  actual_check_in        DateTime? @db.Timestamp(0)
  condition_at_check_out String?   @db.Text
  condition_at_check_in  String?   @db.Text
  image_url_before       String?   @db.Text
  image_url_after        String?   @db.Text
  notes                  String?   @db.Text
  is_extended            Boolean   @default(false)
  rating                 Int?
  feedback               String?   @db.Text

  // Audit Trail
  created_by Int?
  updated_by Int?
  updated_at DateTime @updatedAt @db.Timestamp(0)

  // Relations
  equipment   Equipment @relation(fields: [equipment_id], references: [id])
  borrower    User      @relation("BorrowerTransactions", fields: [borrower_id], references: [id])
  approver    User?     @relation("ApproverTransactions", fields: [approver_id], references: [id])
  storekeeper User?     @relation("StorekeeperTransactions", fields: [storekeeper_id], references: [id])

  @@map("transactions")
}

model MaintenanceHistory {
  id                    Int       @id @default(autoincrement())
  equipment_id          Int
  maintenance_date      DateTime? @db.Date
  performed_by          String?   @db.VarChar(255)
  details               String?   @db.Text
  cost                  Decimal?  @db.Decimal(15, 2)
  next_maintenance_date DateTime? @db.Date

  equipment Equipment @relation(fields: [equipment_id], references: [id])

  @@map("maintenance_history")
}

model Notification {
  id         Int      @id @default(autoincrement())
  user_id    Int
  title      String   @db.VarChar(255)
  message    String   @db.Text
  type       String   @db.VarChar(50) // system, borrow, return, etc.
  is_read    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(0)

  user User @relation(fields: [user_id], references: [id])

  @@map("notifications")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  user_id     Int
  action      String   @db.VarChar(100)
  target_type String   @db.VarChar(100) // Equipment, User, Transaction, etc.
  target_id   Int?
  details     String?  @db.Text
  created_at  DateTime @default(now()) @db.Timestamp(0)

  user User @relation(fields: [user_id], references: [id])

  @@map("audit_logs")
}
